local function refreshGUI()
if not screenGui.Parent or not scrollingFrame.Parent or minimized then return end
local existing=getExistingEntries()
if #existing>#logBuffer then
for i=#logBuffer+1,#existing do if existing[i]then existing[i]:Destroy()end end
existing=getExistingEntries()
end
if #existing<#logBuffer then
for i=#existing+1,#logBuffer do if logBuffer[i]then createLogEntry(logBuffer[i],i)end end
existing=getExistingEntries()
end
for i,entry in ipairs(logBuffer)do
local container=existing[i]
if container then
container.LayoutOrder=i
local label=container:FindFirstChild("LogLine")
if label then
if label.Text~=entry.text then label.Text=entry.text end
applyLogColor(label,entry.level)
end
end
end
